programa {
  funcao inicio() {
    real baseMaior, baseMenor, altura, area 

    escreva("base Maior: ")
    leia(baseMaior)

    escreva("base Menor: ")
    leia(baseMenor)

    escreva("Altura: ")
    leia(altura)

    area=((baseMaior+baseMenor)*altura)/2
    escreva("Área do trapézio: ", area)
   
  }
}

